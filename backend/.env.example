NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000
PUBLIC_SOCKET_URL=http://localhost:5000
UPLOAD_DIR=uploads

DB_HOST=localhost
DB_PORT=3306

# MySQL Workbench 8.0 CE usa as mesmas credenciais do MySQL Server.
# Se voce entra no Workbench como root com senha, coloque essa senha aqui.
DB_USER=root
DB_PASSWORD=your-mysql-workbench-password
DB_NAME=privychat

JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

RATE_LIMIT_API_MAX=240
RATE_LIMIT_AUTH_MAX=300

MESSAGE_SECRET=32-character-minimum-message-secret
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
